# --- Local dev ---
# Vite dev server proxies /api -> http://localhost:8000 (see vite.config.ts).
# Leave VITE_API_BASE_URL unset locally; the proxy handles routing.
VITE_API_BASE_URL=/api

# --- Production (Vercel) ---
# Set this in Vercel Dashboard -> Settings -> Environment Variables -> Production.
# Point at your HF Space URL where the FastAPI service runs:
#   VITE_API_BASE_URL=https://<your-username>-faraday.hf.space
#
# Preview deploys (Vercel auto-PRs) inherit the same value unless overridden
# in the Preview environment.
